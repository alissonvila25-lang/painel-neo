# Credenciais do Portal Ayty (tenant NEO). Copie para secrets.toml e preencha.
# No Streamlit Cloud: cole em "Settings -> Secrets".

# Login do portal (CPF) e senha do cliente NEO.
AYTY_PORTAL_USER = "seu-login-cpf"
AYTY_PORTAL_SENHA = "coloque-a-senha-aqui"

# (opcional) senha unica de acesso ao painel. Se preencher [credentials] no fim,
# esta e ignorada. Se vazio e sem [credentials], o painel fica aberto.
NEO_PANEL_SENHA = ""

# --- Treinamento / auto-calibracao (Google Sheets) ---
# Reusa a MESMA conta de servico do outro painel, numa planilha DEDICADA do NEO.
# Cole o MESMO GCP_SERVICE_ACCOUNT_JSON do outro painel e compartilhe a planilha
# do NEO como EDITOR com o client_email dessa conta de servico.
GCP_SERVICE_ACCOUNT_JSON = '{"type":"service_account", "...":"cole aqui o mesmo do outro painel"}'
# TREINO_SHEET_ID ja aponta por padrao para a planilha dedicada do NEO:
# TREINO_SHEET_ID = "1WsG0HuAMwgoqANEMgTslEE-_0_NRFdS1BMjAYBc6-mI"

# (opcional) sobrescrever o tenant do portal:
# AYTY_PORTAL_BASE = "https://app76.digitalcontact.cloud/AYTY/AppINTEGRACAO/AytyPortalExFrontEndWeb"
# AYTY_PORTAL_ORIGIN = "https://app76.digitalcontact.cloud"

# --- Acessos por usuario (recomendado) ---
# Login pede USUARIO + SENHA. Cada linha = um acesso.
# IMPORTANTE: [credentials] fica SEMPRE POR ULTIMO. NAO coloque chaves depois.
[credentials]
daniel = "senha-do-daniel"
supervisao = "senha-da-supervisao"
alisson = "senha-do-admin"
